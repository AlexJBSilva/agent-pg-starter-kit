{
  "name": "agent-pg-starter-kit",
  "version": "0.1.0",
  "description": "PostgreSQL-backed API layer for Agent Starter Kit framework",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "sync": "ts-node src/sync/index.ts",
    "db:init": "psql $DATABASE_URL -f src/db/schema.sql",
    "db:migrate": "ts-node src/db/migrations/run.ts",
    "db:rollback": "ts-node src/db/migrations/rollback.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": [
    "agent",
    "ai",
    "postgres",
    "api",
    "framework"
  ],
  "author": "AlexJBSilva",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "yaml": "^2.3.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  }
}
